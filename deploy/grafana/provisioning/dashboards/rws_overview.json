{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "RWS — Robot Weapon Station real-time operational dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Fire Control",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "SAFE"}, "1": {"text": "ARMED"}, "2": {"text": "AUTHORIZED"}, "3": {"text": "REQUESTED"}, "4": {"text": "FIRED"}, "5": {"text": "COOLDOWN"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 1},
            {"color": "red", "value": 3}
          ]}
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "rws_fire_chain_state", "instant": true, "legendFormat": "state"}],
      "title": "Fire Chain State",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "rws_shots_fired_total", "instant": true, "legendFormat": "shots"}],
      "title": "Shots Fired",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 5},
            {"color": "red", "value": 10}
          ]},
          "unit": "s"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "rws_operator_heartbeat_age_s", "instant": true, "legendFormat": "heartbeat age"}],
      "title": "Operator Heartbeat Age",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}, {"color": "green", "value": 1}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "rws_tracks_total", "instant": true, "legendFormat": "tracks"}],
      "title": "Active Tracks",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 15},
            {"color": "green", "value": 25}
          ]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "id": 5,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "rws_pipeline_fps", "legendFormat": "fps"}],
      "title": "Pipeline FPS",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101,
      "title": "System Health",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "unknown", "color": "grey"}, "1": {"text": "ok", "color": "green"}, "2": {"text": "degraded", "color": "yellow"}, "3": {"text": "failed", "color": "red"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "grey", "value": null},
            {"color": "green", "value": 1},
            {"color": "yellow", "value": 2},
            {"color": "red", "value": 3}
          ]}
        }
      },
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 6},
      "id": 10,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "rws_health_subsystem", "instant": true, "legendFormat": "{{name}}"}],
      "title": "Subsystem Health",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 11},
      "id": 102,
      "title": "Tracking",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisPlacement": "auto", "lineWidth": 2}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 20,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "rws_tracks_total", "legendFormat": "total tracks"},
        {"datasource": {"type": "prometheus"}, "expr": "rws_lifecycle_by_state{state=\"tracked\"}", "legendFormat": "tracked"},
        {"datasource": {"type": "prometheus"}, "expr": "rws_lifecycle_by_state{state=\"locked\"}", "legendFormat": "locked"},
        {"datasource": {"type": "prometheus"}, "expr": "rws_lifecycle_by_state{state=\"engaged\"}", "legendFormat": "engaged"}
      ],
      "title": "Track Count over Time",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisPlacement": "auto", "lineWidth": 2}, "unit": "short", "min": 0, "max": 1},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 21,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "rws_threat_score", "legendFormat": "track {{track_id}}"}
      ],
      "title": "Threat Scores",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 20},
      "id": 103,
      "title": "Performance",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisPlacement": "auto", "lineWidth": 2}, "unit": "short", "min": 0},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 21},
      "id": 30,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "rws_pipeline_fps", "legendFormat": "pipeline fps"}
      ],
      "title": "Pipeline Throughput",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["rws", "tracking", "weapon-station"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "RWS — Robot Weapon Station",
  "uid": "rws-overview",
  "version": 1
}

# ============================================================
# RWS Environment Configuration
# ============================================================
# Copy this file to .env and customise before running Docker:
#   cp .env.example .env
#
# Docker Compose reads .env automatically.
# ============================================================

# ------------------------------------------------------------
# API Security
# Set a non-empty value to enable HMAC token auth on fire-control
# endpoints (/api/fire/*). Leave empty to disable auth (dev only).
# ------------------------------------------------------------
RWS_API_KEY=

# ------------------------------------------------------------
# Operator Watchdog
# If no /api/fire/heartbeat is received within this many seconds
# the ShootingChain is forced back to SAFE automatically.
# Default: 10 seconds.
# ------------------------------------------------------------
RWS_OPERATOR_TIMEOUT=10

# ------------------------------------------------------------
# Logging
# Log verbosity: DEBUG | INFO | WARNING | ERROR
# Default: INFO
# ------------------------------------------------------------
RWS_LOG_LEVEL=INFO

# ------------------------------------------------------------
# Backend network (used when running locally without Docker)
# ------------------------------------------------------------
RWS_HOST=0.0.0.0
RWS_PORT=5000

# ------------------------------------------------------------
# Grafana admin password
# Change before any internet-facing deployment.
# Default: admin
# ------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin

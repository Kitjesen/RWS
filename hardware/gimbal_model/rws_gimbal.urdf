<?xml version="1.0"?>
<!--
  RWS 2-DOF Pan-Tilt Gimbal — URDF Model
  =========================================
  Kinematics
  ----------
  world (fixed)
    └─ base_link (mounting plate, 150×150×50 mm)
         └─ yaw_joint   (revolute, Z-axis, ±160 deg, 240 dps max)
              └─ yaw_link   (pan motor + housing, Ø80×60 mm)
                   └─ pitch_joint  (revolute, Y-axis, −45° … +75°, 240 dps max)
                        └─ pitch_link  (camera carrier, 100×60×70 mm)
                             └─ camera_optical_joint  (fixed)
                                  └─ camera_link  (lens, Ø50×30 mm)

  Coordinate convention
  ----------------------
  +X  =  camera boresight (forward)
  +Z  =  up
  Yaw  positive = rotate right (CW from above)
  Pitch positive = tilt up

  Inertia values are approximate for a ≈0.8 kg aluminium gimbal.

  Compatible with: ROS/Gazebo, RViz, PyBullet (pybullet_data), MuJoCo, Drake.
-->

<robot name="rws_gimbal">

  <!-- ══════════════════════  MATERIALS  ══════════════════════ -->
  <material name="aluminium">
    <color rgba="0.75 0.75 0.78 1.0"/>
  </material>
  <material name="motor_blue">
    <color rgba="0.15 0.40 0.80 1.0"/>
  </material>
  <material name="camera_body">
    <color rgba="0.20 0.20 0.20 1.0"/>
  </material>
  <material name="lens_black">
    <color rgba="0.05 0.05 0.05 0.9"/>
  </material>
  <material name="accent_red">
    <color rgba="0.85 0.18 0.10 1.0"/>
  </material>

  <!-- ══════════════════════  BASE LINK  ══════════════════════ -->
  <!--  Mounting plate — bolted to robot chassis or tripod.      -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.150 0.150 0.050"/></geometry>
      <material name="aluminium"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.025" rpy="0 0 0"/>
      <geometry><box size="0.150 0.150 0.050"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.025" rpy="0 0 0"/>
      <mass value="0.400"/>
      <!-- Solid rectangular plate: I = m/12*(a²+b²) -->
      <inertia ixx="0.000750" iyy="0.000750" izz="0.001500"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ══════════════════════  YAW JOINT  ══════════════════════ -->
  <!--  Pan axis: rotates the camera left/right around +Z.
        Limits: ±160 deg (±2.7925 rad).
        Max rate: 240 dps = 4.1888 rad/s.                        -->
  <joint name="yaw_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="yaw_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="-2.7925" upper="2.7925"
            effort="8.0"    velocity="4.1888"/>
    <dynamics damping="0.02" friction="0.05"/>
  </joint>

  <!-- ══════════════════════  YAW LINK  ════════════════════════ -->
  <!--  Pan motor housing + slip-ring assembly.                   -->
  <link name="yaw_link">
    <!-- Cylindrical motor body -->
    <visual>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <geometry><cylinder radius="0.040" length="0.060"/></geometry>
      <material name="motor_blue"/>
    </visual>
    <!-- Mounting ears (two small boxes, +/−Y) -->
    <visual>
      <origin xyz="0  0.048 0.055" rpy="0 0 0"/>
      <geometry><box size="0.020 0.016 0.020"/></geometry>
      <material name="aluminium"/>
    </visual>
    <visual>
      <origin xyz="0 -0.048 0.055" rpy="0 0 0"/>
      <geometry><box size="0.020 0.016 0.020"/></geometry>
      <material name="aluminium"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <geometry><cylinder radius="0.040" length="0.060"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <mass value="0.220"/>
      <!-- Solid cylinder: Ixx = Iyy = m/12*(3r²+h²), Izz = m/2*r² -->
      <inertia ixx="0.000285" iyy="0.000285" izz="0.000176"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ══════════════════════  PITCH JOINT  ═════════════════════ -->
  <!--  Tilt axis: rotates the camera up/down around +Y (of yaw frame).
        Limits: −45° … +75° (−0.7854 … 1.3090 rad).
        Positive pitch = camera tilts up.                         -->
  <joint name="pitch_joint" type="revolute">
    <parent link="yaw_link"/>
    <child  link="pitch_link"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  lower="-0.7854" upper="1.3090"
            effort="4.0"    velocity="4.1888"/>
    <dynamics damping="0.01" friction="0.03"/>
  </joint>

  <!-- ══════════════════════  PITCH LINK  ══════════════════════ -->
  <!--  Camera carrier / tilt arm.                                -->
  <link name="pitch_link">
    <!-- Main camera body -->
    <visual>
      <origin xyz="0.040 0 0" rpy="0 0 0"/>
      <geometry><box size="0.100 0.060 0.065"/></geometry>
      <material name="camera_body"/>
    </visual>
    <!-- Tilt motor (visible on +Y side) -->
    <visual>
      <origin xyz="0 0.050 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.022" length="0.025"/></geometry>
      <material name="accent_red"/>
    </visual>
    <collision>
      <origin xyz="0.040 0 0" rpy="0 0 0"/>
      <geometry><box size="0.100 0.060 0.065"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.040 0 0" rpy="0 0 0"/>
      <mass value="0.150"/>
      <inertia ixx="0.000115" iyy="0.000150" izz="0.000135"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ══════════════════════  CAMERA OPTICAL JOINT  ════════════ -->
  <!--  Fixed offset from pitch_link to camera boresight.        -->
  <joint name="camera_optical_joint" type="fixed">
    <parent link="pitch_link"/>
    <child  link="camera_link"/>
    <!-- Lens face at +95 mm along X from pitch origin -->
    <origin xyz="0.095 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ══════════════════════  CAMERA LINK  ═════════════════════ -->
  <!--  Lens assembly (visual only, negligible inertia).          -->
  <link name="camera_link">
    <!-- Lens barrel -->
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.025" length="0.030"/></geometry>
      <material name="lens_black"/>
    </visual>
    <!-- Lens glass (slightly convex look) -->
    <visual>
      <origin xyz="0.016 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.020" length="0.002"/></geometry>
      <material name="motor_blue"/>
    </visual>
    <inertial>
      <mass value="0.050"/>
      <inertia ixx="0.000010" iyy="0.000010" izz="0.000010"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

</robot>
